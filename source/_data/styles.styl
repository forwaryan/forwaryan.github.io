.post-body .code-container:has(.mermaid),
.post-body .mermaid-enhanced-container {
  position: relative;
  box-sizing: border-box;
  width: 100%;
  max-width: 100%;
  margin: 1.4rem auto;
  padding: 18px 18px 16px;
  overflow-x: auto;
  overflow-y: hidden;
  border: 1px solid #e5e7eb;
  border-radius: 4px;
  background: #fff;
  box-shadow: 0 1px 2px rgba(15, 23, 42, .04);
}

.post-body .code-container:has(.mermaid)::before,
.post-body .mermaid-enhanced-container::before {
  content: "Mermaid";
  position: absolute;
  top: 8px;
  left: 12px;
  color: #94a3b8;
  font-size: 11px;
  line-height: 1;
  letter-spacing: 0;
}

.post-body .code-container:has(.mermaid) .copy-btn,
.post-body .mermaid-enhanced-container .copy-btn {
  display: none;
}

.post-body .code-container:has(.mermaid) .mermaid,
.post-body .mermaid-enhanced-container .mermaid {
  display: flex;
  justify-content: center;
  min-width: 0;
  padding-top: 10px;
  text-align: center;
}

.post-body .mermaid svg {
  display: block;
  height: auto !important;
  max-width: 100% !important;
  margin: 0 auto;
  cursor: zoom-in;
}

.post-body .mermaid svg text,
.mermaid-lightbox__surface svg text {
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC", "Microsoft YaHei", sans-serif !important;
  fill: #1f2937 !important;
}

.post-body .mermaid svg .node rect,
.post-body .mermaid svg .node polygon,
.post-body .mermaid svg .node circle,
.post-body .mermaid svg .node ellipse,
.mermaid-lightbox__surface svg .node rect,
.mermaid-lightbox__surface svg .node polygon,
.mermaid-lightbox__surface svg .node circle,
.mermaid-lightbox__surface svg .node ellipse {
  fill: #f8fafc !important;
  stroke: #94a3b8 !important;
  stroke-width: 1.2px !important;
}

.post-body .mermaid svg .cluster rect,
.mermaid-lightbox__surface svg .cluster rect {
  fill: #fbfdff !important;
  stroke: #cbd5e1 !important;
  stroke-width: 1.2px !important;
}

.post-body .mermaid svg .edgePath path,
.post-body .mermaid svg .flowchart-link,
.mermaid-lightbox__surface svg .edgePath path,
.mermaid-lightbox__surface svg .flowchart-link {
  stroke: #64748b !important;
  stroke-width: 1.4px !important;
}

.post-body .mermaid svg marker path,
.mermaid-lightbox__surface svg marker path {
  fill: #64748b !important;
  stroke: #64748b !important;
}

.post-body .mermaid svg .edgeLabel,
.post-body .mermaid svg .edgeLabel p,
.mermaid-lightbox__surface svg .edgeLabel,
.mermaid-lightbox__surface svg .edgeLabel p {
  background: #fff !important;
  color: #374151 !important;
}

.post-body .mermaid svg .actor,
.mermaid-lightbox__surface svg .actor {
  fill: #f8fafc !important;
  stroke: #94a3b8 !important;
}

.post-body .mermaid svg .messageLine0,
.post-body .mermaid svg .messageLine1,
.post-body .mermaid svg .loopLine,
.mermaid-lightbox__surface svg .messageLine0,
.mermaid-lightbox__surface svg .messageLine1,
.mermaid-lightbox__surface svg .loopLine {
  stroke: #64748b !important;
}

.post-body .mermaid svg .note,
.mermaid-lightbox__surface svg .note {
  fill: #fff7ed !important;
  stroke: #fed7aa !important;
}

.post-toc {
  font-size: 13px;
}

.post-toc ol {
  padding-right: 0;
  padding-left: 8px;
}

.post-toc .nav .nav-child {
  padding-left: 10px;
}

.post-toc .nav-item {
  margin: 4px 0;
  line-height: 1.65;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.post-toc .nav-item a {
  display: inline-block;
  max-width: 100%;
  box-sizing: border-box;
  vertical-align: top;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.toc-title-tooltip {
  position: fixed;
  z-index: 110;
  max-width: 420px;
  padding: 7px 10px;
  border: 1px solid #d8dee9;
  border-radius: 4px;
  background: #fff;
  color: #3b4252;
  box-shadow: 0 8px 24px rgba(15, 23, 42, 0.14);
  font-size: 13px;
  line-height: 1.5;
  pointer-events: none;
  white-space: normal;
  overflow-wrap: anywhere;
  opacity: 0;
  transform: translate3d(0, -50%, 0);
  transition: opacity 0.12s ease;
}

.toc-title-tooltip.is-visible {
  opacity: 1;
}

.mermaid-zoom-button {
  position: absolute;
  z-index: 2;
  top: 8px;
  right: 10px;
  padding: 3px 8px;
  border: 1px solid #d1d5db;
  border-radius: 4px;
  background: #fff;
  color: #64748b;
  font-size: 12px;
  line-height: 1.4;
  cursor: pointer;
}

.mermaid-zoom-button:hover,
.mermaid-zoom-button:focus {
  border-color: #94a3b8;
  color: #1f2937;
}

.mermaid-lightbox-open {
  overflow: hidden;
}

.mermaid-lightbox {
  position: fixed;
  z-index: 9999;
  inset: 0;
  display: flex;
  flex-direction: column;
  background: rgba(17, 24, 39, .82);
}

.mermaid-lightbox__toolbar {
  display: flex;
  align-items: center;
  gap: 8px;
  min-height: 50px;
  padding: 8px 14px;
  border-bottom: 1px solid rgba(255, 255, 255, .12);
  color: #f8fafc;
}

.mermaid-lightbox__title {
  margin-right: auto;
  font-size: 14px;
}

.mermaid-lightbox__button {
  min-width: 34px;
  padding: 5px 10px;
  border: 1px solid rgba(226, 232, 240, .36);
  border-radius: 4px;
  background: rgba(255, 255, 255, .1);
  color: #f8fafc;
  font-size: 13px;
  line-height: 1.3;
  cursor: pointer;
}

.mermaid-lightbox__button:hover,
.mermaid-lightbox__button:focus {
  background: rgba(255, 255, 255, .18);
}

.mermaid-lightbox__scale {
  min-width: 48px;
  text-align: center;
  font-size: 13px;
}

.mermaid-lightbox__viewport {
  flex: 1;
  overflow: auto;
  padding: 28px;
  cursor: grab;
  touch-action: none;
  user-select: none;
}

.mermaid-lightbox__viewport.is-dragging {
  cursor: grabbing;
}

.mermaid-lightbox__stage {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: max-content;
  min-height: max-content;
}

.mermaid-lightbox__content {
  position: relative;
  flex: 0 0 auto;
}

.mermaid-lightbox__surface {
  position: absolute;
  top: 0;
  left: 0;
  display: inline-block;
  padding: 24px;
  border-radius: 4px;
  background: #fff;
  box-shadow: 0 20px 60px rgba(0, 0, 0, .32);
  transform-origin: top left;
}

.mermaid-lightbox__surface svg {
  display: block;
  max-width: none !important;
}

@media (max-width: 767px) {
  .post-body .code-container:has(.mermaid),
  .post-body .mermaid-enhanced-container {
    margin: 1.2rem auto;
    padding: 16px 12px 14px;
  }

  .mermaid-lightbox__viewport {
    padding: 14px;
  }
}
